# Megavibe — .agent/.gitignore
# Track: FULL_CONTEXT.md, DECISIONS.md, TASKS.md, LESSONS.md, RESEARCH/
# Ignore: everything ephemeral, binary, or regenerable

# Session-scoped state (per-session WORKING_CONTEXT, counters, flags)
sessions/

# Legacy root-level WORKING_CONTEXT (replaced by sessions/{sid}/)
WORKING_CONTEXT.md

# Raw logs (high volume, always regenerable from FULL_CONTEXT)
LOGS/

# Binary assets (screenshots, PDFs) — use LFS or skip
ASSETS/*.png
ASSETS/*.jpg
ASSETS/*.pdf
ASSETS/*.html

# Session lock (ephemeral, PID-based)
.session-lock.d/
.session-lock

# Remote control state (ephemeral)
session-history.jsonl
pending-remote.jsonl
events.jsonl

# poma-memory database (regenerable from indexed files)
.poma-memory.db
.poma-memory.db-shm
.poma-memory.db-wal

# .gitkeep files (scaffolding only)
.gitkeep
